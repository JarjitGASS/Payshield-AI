# Copy this file to .env and fill in all values.
# Never commit .env to version control.

# ── Build Stage ───────────────────────────────────────────────────────────────
# Controls which Dockerfile stage is used for backend and frontend.
# Options: "dev" (hot-reload) | "production" (immutable, optimised image)
BUILD_TARGET=dev

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payshield

# Constructed automatically in docker-compose from the values above.
# Override here only if using an external DB (e.g. RDS, Alibaba ApsaraDB).
# DATABASE_URL=postgresql://payshield:change_me@db:5432/payshield

# ── Qwen / Alibaba Model Studio ───────────────────────────────────────────────
QWEN_API_KEY=sk-0831d23e0bef4291a6c5dc275283af8a
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

REDIS_URL=redis://redis:6379/0

SECRET_KEY=replace-with-a-long-random-secret-string
ENVIRONMENT=production

ENABLE_FACE_MATCH=true
ENABLE_ENTITY_SCRAPE=false

VITE_API_URL=
